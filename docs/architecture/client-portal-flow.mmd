%%{ init: { 'theme': 'base' } }%%

graph TD

%% ============================================================
%% CLIENT JOURNEY — 8-STAGE PIPELINE
%% ============================================================

subgraph PIPELINE["8-Stage Report Pipeline"]
    direction TB
    S1["Stage 1: Send_Questionnaire<br/>Office sends Tally link"]
    S2["Stage 2: Waiting_For_Answers<br/>Client fills questionnaire"]
    S3["Stage 3: Pending_Approval<br/>Office reviews submission"]
    S4["Stage 4: Collecting_Docs<br/>Client uploads documents"]
    S5["Stage 5: Review<br/>Ready for preparation"]
    S6["Stage 6: Moshe_Review<br/>CPA final review"]
    S7["Stage 7: Before_Signing<br/>Client signs return"]
    S8["Stage 8: Completed<br/>Filed with tax authority"]
end

%% ============================================================
%% CLIENT PORTAL PAGES — WHICH PAGES AT WHICH STAGE
%% ============================================================

subgraph PAGES["Client Portal Pages"]
    direction TB
    P_LANDING["index.html<br/>Check status + language"]
    P_VIEW["view-documents.html<br/>Document list + upload"]
    P_APPROVE["approve-confirm.html<br/>Review before send"]
end

%% ============================================================
%% REMINDERS
%% ============================================================

subgraph REMINDERS["Automated Reminders"]
    direction TB
    TYPE_A["Type A Reminder<br/>WF[06] — Waiting_For_Answers<br/>Fill your questionnaire"]
    TYPE_B["Type B Reminder<br/>WF[06] — Collecting_Docs<br/>Upload missing documents"]
end

%% ============================================================
%% AUTH FLOW
%% ============================================================

subgraph AUTH["Client Authentication"]
    direction TB
    HMAC["HMAC Token in URL<br/>45-day expiry"]
    WORKER_VERIFY["Cloudflare Worker<br/>Verify token + extract report_id"]
    AIRTABLE_FETCH["Fetch report + documents<br/>from Airtable"]
end

%% ============================================================
%% CONNECTIONS
%% ============================================================

%% Stage triggers
S1 -->|"email with Tally link"| S2
S2 -->|"Type A reminders"| TYPE_A
S3 -->|"office Approve and Send"| S4
S4 -->|"Type B reminders"| TYPE_B
S4 -->|"completion 100%"| S5

%% Page access by stage
S2 -->|"questionnaire link"| P_LANDING
S4 -->|"doc list link"| P_VIEW
S4 -->|"upload via portal"| P_VIEW

%% Auth for all client pages
P_LANDING -->|"token in URL"| HMAC
P_VIEW -->|"token in URL"| HMAC
P_APPROVE -->|"token in URL"| HMAC
HMAC --> WORKER_VERIFY
WORKER_VERIFY --> AIRTABLE_FETCH

%% ============================================================
%% ADMIN ACTIONS
%% ============================================================

subgraph ADMIN_ACTIONS["Office Actions per Stage"]
    direction TB
    A_SEND["Send Questionnaire<br/>Bulk or individual"]
    A_REVIEW["Review + Edit Docs<br/>Document Manager"]
    A_APPROVE["Approve and Send<br/>Triggers client email"]
    A_STAGE["Change Stage<br/>Manual advance"]
    A_COMPLETE["Mark Complete<br/>Final stage"]
end

S1 --- A_SEND
S3 --- A_REVIEW
S3 --- A_APPROVE
S5 --- A_STAGE
S8 --- A_COMPLETE

