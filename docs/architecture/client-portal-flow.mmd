classDef stage fill:#ede9fe,stroke:#7c3aed,stroke-width:2px
classDef page fill:#dbeafe,stroke:#2563eb,stroke-width:2px
classDef reminder fill:#fef3c7,stroke:#d97706,stroke-width:2px
classDef auth fill:#f0fdf4,stroke:#16a34a,stroke-width:2px
classDef admin fill:#fce7f3,stroke:#db2777,stroke-width:2px

class S1,S2,S3,S4,S5,S6,S7,S8 stage
class P_LANDING,P_VIEW,P_APPROVE page
class TYPE_A,TYPE_B reminder
class HMAC,WORKER_VERIFY,AIRTABLE_FETCH auth
class A_SEND,A_REVIEW,A_APPROVE,A_STAGE,A_COMPLETE admin
