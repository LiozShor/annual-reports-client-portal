%% ============================================================
%% DATA FLOWS
%% ============================================================

%% Client submission flow
TALLY_HE -->|"webhook"| WF02
TALLY_EN -->|"webhook"| WF02
WF02 -->|"call sub-workflow"| WF_SUB
WF02 -->|"create docs"| AT_DOCS
WF02 -->|"update stage"| AT_REPORTS
WF02 -->|"send office email"| MSGRAPH

%% Document Service reads templates
WF_SUB -->|"read templates"| AT_TEMPLATES
WF_SUB -->|"read mappings"| AT_MAPPINGS
WF_SUB -->|"read categories"| AT_CATEGORIES

%% Admin portal flows
DASHBOARD -->|"Bearer token"| W_AUTH
DASHBOARD -->|"fetch data"| W_DASH
DASHBOARD -->|"review AI"| W_CLASS
DOCMGR -->|"edit docs"| W_DOCS
DOCMGR -->|"change stage"| W_STAGE

%% Workers to Airtable
W_DASH -->|"query"| AT_REPORTS
W_DOCS -->|"CRUD"| AT_DOCS
W_CLASS -->|"review"| AT_PENDING
W_STAGE -->|"update stage"| AT_REPORTS
W_EMAIL -->|"send via"| MSGRAPH
W_DOCS -->|"upload files"| MSGRAPH
W_EMAIL -->|"trigger"| WF_API

%% Client portal flows
LANDING -->|"check submission"| WORKERS
VIEWDOCS -->|"get documents"| W_DOCS
APPROVE -->|"approve + send"| W_EMAIL

%% Inbound email processing (via Workers)
MSGRAPH -->|"new email"| W_EMAIL
W_EMAIL -->|"classify"| CLAUDE_AI
W_EMAIL -->|"create pending"| AT_PENDING
W_EMAIL -->|"save file"| MSGRAPH
W_EMAIL -->|"update doc"| AT_DOCS

%% Reminders
WF06 -->|"check due"| AT_REPORTS
WF06 -->|"send reminder"| MSGRAPH
WF06SUB -->|"reset counters"| AT_REPORTS

%% Daily digest
WF07 -->|"summarize"| CLAUDE_AI
WF07 -->|"query activity"| AT_REPORTS
WF07 -->|"send digest"| MSGRAPH

%% Batch status (Workers → n8n)
WF_API -->|"generate email"| WF_SUB
WF_API -->|"send"| MSGRAPH

%% Monitoring
WF_MON1 -->|"scan logs"| AT_EMAIL
UPTIMEROBOT -->|"ping"| WORKERS

%% HMAC auth for client links
PORTAL -.-|"HMAC token in URL"| WORKERS

