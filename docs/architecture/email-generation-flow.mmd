%%{ init: { 'theme': 'base' } }%%

graph TD

%% ============================================================
%% EMAIL TYPES AND GENERATION
%% ============================================================

subgraph TRIGGERS["Email Trigger Sources"]
    direction TB
    T_TALLY["Tally Submission<br/>WF[02] webhook"]
    T_APPROVE["Office Approve + Send<br/>Workers API"]
    T_BATCH["Batch Status Update<br/>[API] Send Batch Status"]
    T_REMINDER["Reminder Due<br/>WF[06] cron"]
    T_DIGEST["Daily Digest<br/>WF[07] cron 15:00 + 20:00"]
    T_STATUS["Doc Status Change<br/>Workers API"]
end

subgraph DOCSVC["[SUB] Document Service — SSOT Engine"]
    direction TB
    LOAD["Load from Airtable<br/>templates + mappings + categories"]
    GENERATE["Generate document array<br/>Apply 60 mapping rules"]
    HTML_OFFICE["Render office HTML<br/>Full: header + questionnaire<br/>+ doc list + action buttons"]
    HTML_CLIENT["Render client HTML<br/>Bilingual cards<br/>EN primary + HE secondary"]
    HTML_BATCH["Render batch status HTML<br/>Doc progress + counts"]
end

subgraph DELIVERY["Email Delivery — MS Graph API"]
    direction TB
    GRAPH_SEND["Graph API sendMail<br/>from: reports@moshe-atsits.co.il"]
    TRACK["Track in Airtable<br/>email_events table"]
end

%% ============================================================
%% EMAIL TYPE DETAILS
%% ============================================================

subgraph TYPES["Email Types"]
    direction TB
    E_OFFICE["Office Notification<br/>New questionnaire received<br/>Doc list + Approve/Edit buttons"]
    E_CLIENT_DOCS["Client Doc Request<br/>Bilingual doc list<br/>CTA: upload via portal"]
    E_BATCH["Batch Status<br/>Updated doc progress<br/>Completion percentage"]
    E_REMINDER_A["Type A Reminder<br/>Fill your questionnaire<br/>Tally link"]
    E_REMINDER_B["Type B Reminder<br/>Upload missing documents<br/>Portal link"]
    E_DIGEST_N["Natan Digest<br/>Daily activity summary<br/>AI-generated by Claude Haiku"]
    E_DIGEST_M["Moshe Digest<br/>Daily activity summary<br/>AI-generated by Claude Haiku"]
end

%% ============================================================
%% FLOWS
%% ============================================================

T_TALLY --> LOAD
LOAD --> GENERATE
GENERATE --> HTML_OFFICE
GENERATE --> HTML_CLIENT
HTML_OFFICE --> E_OFFICE
HTML_CLIENT --> E_CLIENT_DOCS

T_APPROVE --> HTML_CLIENT
T_BATCH --> HTML_BATCH
HTML_BATCH --> E_BATCH

T_REMINDER -->|"Type A"| E_REMINDER_A
T_REMINDER -->|"Type B"| E_REMINDER_B

T_DIGEST -->|"15:00"| E_DIGEST_N
T_DIGEST -->|"20:00"| E_DIGEST_M

T_STATUS --> E_BATCH

%% All emails go through Graph API
E_OFFICE --> GRAPH_SEND
E_CLIENT_DOCS --> GRAPH_SEND
E_BATCH --> GRAPH_SEND
E_REMINDER_A --> GRAPH_SEND
E_REMINDER_B --> GRAPH_SEND
E_DIGEST_N --> GRAPH_SEND
E_DIGEST_M --> GRAPH_SEND

GRAPH_SEND --> TRACK

%% ============================================================
%% STYLES
%% ============================================================
classDef trigger fill:#fef3c7,stroke:#d97706,stroke-width:2px
classDef engine fill:#ede9fe,stroke:#7c3aed,stroke-width:2px
classDef email fill:#dbeafe,stroke:#2563eb,stroke-width:2px
classDef delivery fill:#f0fdf4,stroke:#16a34a,stroke-width:2px


class T_TALLY,T_APPROVE,T_BATCH,T_REMINDER,T_DIGEST,T_STATUS trigger
class LOAD,GENERATE,HTML_OFFICE,HTML_CLIENT,HTML_BATCH engine
class E_OFFICE,E_CLIENT_DOCS,E_BATCH,E_REMINDER_A,E_REMINDER_B,E_DIGEST_N,E_DIGEST_M email
class GRAPH_SEND,TRACK delivery
